# ============================================
# MedRAG-Vision 配置示例
# ============================================
# 复制此文件为 .env 并修改配置

# === 模型配置 ===
# 文本模型 - 根据显存选择
# 方案 A: 显存 > 24GB (如 A100/3090/4090)
# TEXT_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# 方案 B: 显存 < 16GB (如 T4/3060) - 默认
TEXT_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# 视觉模型
VISION_MODEL_ID=Qwen/Qwen2-VL-2B-Instruct

# === 运行模式 ===
# True = 模拟模式（无需GPU，适合测试）
# False = 真实模型（需要GPU）
USE_MOCK=False

# === 设备 ===
# cuda 或 cpu
DEVICE=cuda